# Copy this file to .env and keep the populated file local.
# The OpenAI-compatible endpoint exposed by the local LLM server.
AUTOCOMP_LLM_ENDPOINT=http://127.0.0.1:8080/v1

# Use the exact model identifier returned by the server's /v1/models endpoint.
AUTOCOMP_LLM_MODEL=local-vision-model

# Leave blank when the local server does not require authentication.
AUTOCOMP_LLM_API_KEY=

# Required by worker-serve. Generate a unique random value of at least 32 characters.
AUTOCOMP_WORKER_TOKEN=
