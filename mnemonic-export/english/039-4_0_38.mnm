AND= @DM0 #0
AND @MR001
ANP MR21700
SET MR8800
SET MR3201
SET MR21710
MOV #10 @DM0
LDB @MR004
AND= @DM0 #10
AND MR5800
SET MR3013
MOV #20 @DM0
LDB @MR004
AND= @DM0 #20
ANB R004
SET MR8804
RES MR3013
MOV #30 @DM0
